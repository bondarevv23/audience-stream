{
  "manifest_version": 3,
  "name": "Audience-Stream",
  "version": "1.0",

  "permissions": [
    "tabs"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html"
  },

  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "192": "icon192.png"
  }
}